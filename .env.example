# Log level configuration for the frontend logger
# Valid values: trace, debug, info, warn, error
# Default: info (in development and production)
VITE_LOG_LEVEL=debug

# Log level configuration for the Tauri backend logger
# Valid values: trace, debug, info, warn, error
# Default: debug (in development), info (in production)
TAURI_LOG_LEVEL=info

#NOTE Only for development login
VITE_AUTH_TYPE=token
VITE_SERVER_URL=YOUR_SERVER_URL  # e.g., miniflux.example.com (without https://)
VITE_API_KEY=YOUR_KEY

# ── Cloud Sync Testing ────────────────────────────────
# S3-compatible storage (LocalStack, MinIO, AWS S3, etc.)
CLOUD_SYNC_S3_ENDPOINT=http://localhost:4566
CLOUD_SYNC_S3_BUCKET=minikyu-test
CLOUD_SYNC_S3_REGION=us-east-1
CLOUD_SYNC_S3_ACCESS_KEY=test
CLOUD_SYNC_S3_SECRET_KEY=test
CLOUD_SYNC_S3_OBJECT_KEY=minikyu/preferences-sync.json

# WebDAV storage (Nextcloud, ownCloud, etc.)
CLOUD_SYNC_WEBDAV_URL=http://192.168.50.178:3645
CLOUD_SYNC_WEBDAV_USERNAME=niskan516
CLOUD_SYNC_WEBDAV_PASSWORD=95041026q
CLOUD_SYNC_WEBDAV_PATH=/minikyu/preferences-sync.json
